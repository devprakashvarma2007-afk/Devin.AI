{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A single message in a chat conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant", "system"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role", "content", "timestamp"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat conversation thread",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "messages": {
          "type": "array",
          "items": { "$ref": "Message" }
        },
        "mode": { "type": "string", "enum": ["chat", "image", "code"] },
        "model": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["messages", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/users/{uid}/chats/{chatId}": {
      "schema": "Chat",
      "description": "User chat conversations"
    }
  }
}
